  "oneShotAggressiveContextSavingsExample": {
    "mode": "one-shot",
    "prompt": "Implement the feature end-to-end while minimizing repeated context cost across planning, implementation, and review steps.",
    "useCase": "coding",
    "customImplementPrompt": "Prefer small reversible edits, keep the current unit self-contained, and report blockers instead of guessing.",
    "agents": ["claude", "codex", "gemini"],
    "context": {
      "dir": "./context",
      "deliveryPolicy": {
        "default": "digest",
        "implementInitial": "full",
        "implementRepair": "none"
      }
    },
    "settings": {
      "timeoutMs": 180000,
      "continueOnError": false,
      "writeScratchpad": true,
      "planLoops": 2,
      "qualityLoops": 2,
      "sectionImplementLoops": 2,
      "oneShotOrigins": {
        "plan": "claude",
        "implement": "codex",
        "review": "gemini"
      },
      "agentPolicies": {
        "codex": { "canWrite": true }
      }
    }
  },
  "reviewWithLocalProviderExample": {
    "task": "Review and summarize this research document",
    "mode": "review",
    "agents": ["nim-local"],
    "context": {
      "dir": "./context",
      "maxFilesPerPhase": {
        "review": 6
      },
      "deliveryPolicy": {
